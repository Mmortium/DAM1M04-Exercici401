<section class="bloc">
    <div class="fila-header">
        <h2>👥 Gestió de Clients</h2>
        <a href="/clientAfegir" class="bto bto-success">+ Nou Client</a>
    </div>
  
    <div class="accions-taula">
        <form action="/clients" method="GET" class="fila">
            <input type="text" name="cerca" value="{{cerca}}" placeholder="Nom o email...">
            <button type="submit" class="bto">Buscar</button>
        </form>
        <a href="/clients?vip=true" class="bto" style="background-color: #f1c40f; color: #000;">🌟 Mostrar VIPs</a>
        <a href="/clients" class="bto-sm">Tots</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>Nom</th>
                <th>Email</th>
                <th>Telèfon</th>
                <th># Compres</th>
                <th>Accions</th>
            </tr>
        </thead>
        <tbody>
            {{#each clients}}
            <tr>
                <td>{{this.name}}</td>
                <td>{{this.email}}</td>
                <td>{{this.phone}}</td>
                <td><span class="badge">{{this.num_compres}}</span></td>
                <td>
                    <a href="/clientEditar?id={{this.id}}" class="bto-sm">Editar</a>
                    <a href="/clientFitxa?id={{this.id}}" class="bto-sm" style="background: var(--accent)">Fitxa</a>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
  
    <div class="paginacio">
        {{#if pagina}}
            <a href="/clients?pagina={{prev}}&cerca={{cerca}}" class="bto">Anterior</a>
        {{/if}}
        <span>Pàgina {{pagina}}</span>
        <a href="/clients?pagina={{next}}&cerca={{cerca}}" class="bto">Següent</a>
    </div>
</section>
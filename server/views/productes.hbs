<section class="bloc">
    <h2>Gestió de Productes</h2>
    
    <form action="/productes" method="GET" class="fila">
        <input type="text" name="cerca" value="{{cerca}}" placeholder="Cerca per nom...">
        <button type="submit">Filtrar</button>
    </form>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Preu</th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>
            {{#each productes}}
            <tr class="{{colorStock this.stock}}">
                <td>{{this.id}}</td>
                <td>{{this.name}}</td>
                <td>{{this.price}} €</td>
                <td>{{this.stock}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="botons">
        <a href="/productes?pagina={{prev}}&cerca={{cerca}}" class="bto">Anterior</a>
        <span>Pàgina {{pagina}}</span>
        <a href="/productes?pagina={{next}}&cerca={{cerca}}" class="bto">Següent</a>
    </div>
</section>

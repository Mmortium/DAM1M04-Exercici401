<section class="bloc">
    <h2>{{#if producte}}Editar Producte{{else}}Afegir Nou Producte{{/if}}</h2>

    <form id="frmProducte" action="{{#if producte}}/Update{{else}}/create{{/if}}" method="POST">
        
        <input type="hidden" name="taula" value="productes">
        
        {{#if producte}}
            <input type="hidden" name="id" value="{{producte.id}}">
        {{/if}}

        <div class="fila-form">
            <label for="name">Nom del Producte:</label>
            <input type="text" name="name" id="inpNom" value="{{producte.name}}" placeholder="Ex: Pomes de Girona">
            <small class="error-msg" id="err-nom"></small>
        </div>

        <div class="fila-form">
            <label for="category">Categoria:</label>
            <input type="text" name="category" id="inpCat" value="{{producte.category}}" placeholder="Ex: Alimentació">
            <small class="error-msg" id="err-cat"></small>
        </div>

        <div class="fila-form">
            <label for="price">Preu (€):</label>
            <input type="number" step="0.01" name="price" id="inpPreu" value="{{producte.price}}">
            <small class="error-msg" id="err-preu"></small>
        </div>

        <div class="fila-form">
            <label for="stock">Stock inicial:</label>
            <input type="number" name="stock" id="inpStock" value="{{producte.stock}}">
            <small class="error-msg" id="err-stock"></small>
        </div>

        <div class="fila-form">
            <label>Actiu:</label>
            <select name="active">
                <option value="1" {{#if producte.active}}selected{{/if}}>Sí</option>
                <option value="0" {{#unless producte.active}}selected{{/unless}}>No</option>
            </select>
        </div>

        <div class="botons">
            <button type="submit" class="bto bto-success">Guardar Producte</button>
            <a href="/productes" class="bto">Cancel·lar</a>
            
            {{#if producte}}
                <button type="submit" formaction="/Delete" class="bto bto-danger" onclick="return confirm('Segur que vols esborrar aquest producte?')">Esborrar</button>
            {{/if}}
        </div>
    </form>
</section>
<form id="formClient" action="{{action}}" method="POST">
  <input type="hidden" name="taula" value="clients">
  {{#if client.id}}<input type="hidden" name="id" value="{{client.id}}">{{/if}}

  <div class="form-group">
    <label>Nom:</label>
    <input type="text" name="name" id="name" class="form-control" value="{{client.name}}">
    <small class="error-text text-danger" id="err-name"></small>
  </div>

  <div class="form-group">
    <label>Email:</label>
    <input type="email" name="email" id="email" class="form-control" value="{{client.email}}">
    <small class="error-text text-danger" id="err-email"></small>
  </div>

  <button type="submit" class="btn btn-success">Guardar</button>
  {{#if client.id}}
    <button formaction="/Delete" method="POST" class="btn btn-danger">Eliminar</button>
  {{/if}}
</form>

<script src="/js/validaClient.js"></script>
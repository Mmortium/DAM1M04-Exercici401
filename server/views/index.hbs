<section class="bloc">
    <div class="pestanyes">
        <button class="tab-btn active" data-target="seccio-kpi">KPIs</button>
        <button class="tab-btn" data-target="seccio-llistats">Llistats</button>
    </div>

    <div id="seccio-kpi" class="tab-content">
        <div style="margin: 15px 0;">
            <button id="btnToggleTauler" class="bto">Alternar Tauler Compacte/Complet</button>
        </div>
        
        <div class="grid-kpi">
            <div class="card">
                <h3>Vendes Avui</h3>
                <p><strong>{{kpis.vAvui}} €</strong></p>
            </div>
            <div class="card kpi-extra">
                <h3>Vendes Mes</h3>
                <p><strong>{{kpis.vMes}} €</strong></p>
            </div>
            <div class="card">
                <h3>Comandes (Avui/Mes)</h3>
                <p>{{kpis.cAvui}} / {{kpis.cMes}}</p>
            </div>
            <div class="card {{#if kpis.alertesStock}}stock-color-on critic{{/if}}">
                <h3>Productes Stock Baix</h3>
                <p>{{kpis.alertesStock}} alertes</p>
            </div>
        </div>
    </div>

    <div id="seccio-llistats" class="tab-content d-none">
        <div style="margin: 15px 0;">
            <button id="btnToggleColors" class="bto">Activar/Desactivar Codi Colors</button>
        </div>

        <h3>Últimes 5 Vendes</h3>
        <table>
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Client</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                {{#each ultimesVendes}}
                <tr>
                    <td>{{this.data}}</td>
                    <td>{{this.client_nom}}</td>
                    <td>{{this.total}} €</td>
                </tr>
                {{/each}}
            </tbody>
        </table>

        <h3>Top 5 Productes Més Venuts</h3>
        <ul>
            {{#each topProductes}}
                <li>{{this.name}}: <strong>{{this.total_venut}} unitats</strong></li>
            {{/each}}
        </ul>
    </div>
</section>